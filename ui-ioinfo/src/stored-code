.outer {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px;
  background-color: #f8f8f8;
  position: relative;
  overflow: hidden; /* important to contain sliding sidebar */
}

.inner {
  margin-bottom: 20px;
}

p {
  text-align: left;
  margin: 8px 0;
}

.sidebar-container {
  position: relative;
  height: auto;
  margin-bottom: 20px;
}

.sidebar-opener {
  cursor: pointer;
  background: #007bff;
  color: white;
  padding: 10px;
  width: fit-content;
  border-radius: 4px;
  margin-bottom: 10px;
}

.sidebar-slider {
  position: absolute;
  top: 40px; /* push below opener */
  left: 0;
  width: 250px;
  background-color: #333;
  color: white;
  transform: translateX(-100%);
  transition: transform 0.3s ease-in-out;
  z-index: 1;
  border-radius: 4px;
  padding: 16px;
}

.sidebar-slide-in {
  transform: translateX(0%);
}

.sidebar-close {
  text-align: right;
  cursor: pointer;
  margin-bottom: 10px;
  font-weight: bold;
  color: #ffcccc;
}

.sidebar-content {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
